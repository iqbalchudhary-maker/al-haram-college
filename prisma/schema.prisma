// ==========================================
// 1. STUDENT & ACADEMIC MODELS
// ==========================================

model Student {
  id              String           @id @default(cuid())
  rollNumber      String           @unique
  fullName        String
  fatherName      String
  gender          String           @default("MALE") // MALE, FEMALE
  dob             DateTime?                         // Date of Birth
  image           String?
  cnic            String?          @unique
  mobile          String
  parentMobile    String
  address         String
  admissionDate   DateTime         @default(now())
  
  // Academic Info
  className       String
  section         String
  session         String
  
  // Financial Configuration
  monthlyFee      Float            @default(0)      // Fixed fee for this student
  discount        Float            @default(0)      // Scholarship/discount
  
  // Relationships
  personalLedger  StudentLedger?                    // Individual student balance
  feeTransactions FeeTransaction[]                  // History of all paid fees
  
  status          String           @default("ACTIVE")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model FeeTransaction {
  id          String   @id @default(cuid())
  amount      Float
  month       String   // e.g., "April 2026"
  date        DateTime @default(now())
  
  // Relations
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
}

model StudentLedger {
  id          String   @id @default(cuid())
  balance     Float    @default(0) // Current dues or advance of student
  
  // Relations
  studentId   String   @unique
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

// ==========================================
// 2. ACCOUNTS & EXPENSE MODELS (College Level)
// ==========================================

model GeneralLedger {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  description String
  type        String   // "INCOME" (e.g. Fees) or "EXPENSE" (e.g. Salaries/Bills)
  
  credit      Float    @default(0) // Paisa aaya (Income)
  debit       Float    @default(0) // Paisa gaya (Expense)
  balance     Float                // Running cash-in-hand balance
  
  // Optional: Link to specific records for tracking
  relatedId   String?  // Can be FeeTransaction ID or Expense ID
  createdAt   DateTime @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  title       String   // e.g., "Electricity Bill", "Teacher Salary"
  category    String   // UTILITY, SALARY, MARKETING, MAINTENANCE
  amount      Float
  description String?
  date        DateTime @default(now())
  paidBy      String?  // Person who handled the cash
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// 3. STAFF / HUMAN RESOURCE
// ==========================================

model Staff {
  id           String   @id @default(cuid())
  name         String
  designation  String
  salary       Float
  joiningDate  DateTime @default(now())
  status       String   @default("ACTIVE") // ACTIVE, RESIGNED, ON_LEAVE
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}